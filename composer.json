{
    "name": "lacv/pipo-scanner",
    "description": "A professional document scanner component for Filament v3/v5, powered by OpenCV.js and jscanify. Capture, crop, filter and upload documents as PDF directly from the browser camera.",
    "keywords": ["filament", "laravel", "scanner", "document", "camera", "pdf", "opencv", "jscanify"],
    "homepage": "https://github.com/LACV/pipo-scanner",
    "license": "MIT",
    "authors": [
        {
            "name": "LACV",
            "homepage": "https://github.com/LACV"
        }
    ],
    "require": {
        "php": "^8.1",
        "filament/filament": "^3.0|^5.0",
        "illuminate/support": "^10.0|^11.0|^12.0|^13.0"
    },
    "autoload": {
        "psr-4": {
            "Lacv\\PipoScanner\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Lacv\\PipoScanner\\PipoScannerServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
